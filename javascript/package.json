{
  "name": "@accestime/api-client",
  "version": "0.1.0",
  "description": "SDK oficial JavaScript/TypeScript para la API de AccesTime",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./webhooks": {
      "import": "./dist/webhooks.js",
      "types": "./dist/webhooks.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
