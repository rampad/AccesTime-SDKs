    "test": "node --test test/"
  },
  "keywords": [
    "accestime",
    "api",
    "sdk",
    "time-tracking",
    "hr",
    "payroll"
  ],
  "author": "AccesTime <soporte@accestime.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.4.0"
  },
  "homepage": "https://docs.accestime.com",
  "repository": "github:accestime/sdk-javascript"
}
